local player = game.Players.LocalPlayer
local lootFolder = workspace:WaitForChild("Loot")
local coreGui = game:GetService("CoreGui")
local UIS = game:GetService("UserInputService")
local VirtualUser = game:GetService("VirtualUser")

--// UI Setup
local sg = Instance.new("ScreenGui", coreGui)
local btn = Instance.new("TextButton", sg)
btn.Size = UDim2.new(0, 150, 0, 50)
btn.Position = UDim2.new(0.1, 0, 0.5, 0)
btn.BackgroundColor3 = Color3.fromRGB(170, 0, 0)
btn.Text = "Auto Collect : OFF"
btn.TextColor3 = Color3.new(1, 1, 1)
btn.Font = Enum.Font.SourceSansBold
btn.TextSize = 18

--// Make UI Movable
local dragging, dragStart, startPos
btn.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = btn.Position
    end
end)

UIS.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        btn.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

btn.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)

--// Logic Variables
local active = false

--// Anti-AFK Logic
-- This is set to fire automatically whenever the game detects you are idle.
player.Idled:Connect(function()
    if active then
        VirtualUser:CaptureController()
        VirtualUser:ClickButton2(Vector2.new(0, 0))
        warn("Anti-AFK triggered: Virtual click sent to prevent kick.")
    end
end)

--// Collection Logic
local function touchLoot()
    local char = player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    for _, folder in pairs(lootFolder:GetChildren()) do
        local target = folder:FindFirstChild("Root")
        if target and target:IsA("BasePart") then
            -- Uses the executor's 'firetouchinterest' to simulate contact
            firetouchinterest(hrp, target, 0) -- Touch
            task.wait() 
            firetouchinterest(hrp, target, 1) -- Untouch
        end
    end
end

--// Button Toggle
btn.MouseButton1Click:Connect(function()
    active = not active
    
    -- UI Feedback
    btn.Text = active and "Auto Collect: ON" or "Auto Collect: OFF"
    btn.BackgroundColor3 = active and Color3.fromRGB(0, 170, 0) or Color3.fromRGB(170, 0, 0)
    
    -- Start Loop
    if active then
        task.spawn(function()
            while active do
                touchLoot()
                task.wait(0.1) -- Runs 10 times per second
            end
        end)
    end
end)
